# Servidor
PORT=3000
NODE_ENV=production
BASE_URL=http://SEU_IP_OU_DOMINIO:3000

# JWT Secret (gere uma string aleatória segura)
JWT_SECRET=sua_chave_secreta_aqui_mude_isso

# Admin padrão (mude após primeiro acesso)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=zip@2024

# Zenvia SMS
ZENVIA_TOKEN=seu_token_zenvia_aqui
ZENVIA_FROM=ZipTelecom

# MikroTik
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=sua_senha_mikrotik
MIKROTIK_HOTSPOT_SERVER=hotspot1

# OTP Config
OTP_EXPIRY_MINUTES=5

# Tempo de acesso gratuito ao hotspot (em minutos)
HOTSPOT_FREE_TIME=60
